script.js
document.getElementById("btnSaibaMais").addEventListener("click", () => {
    document.getElementById("producao").scrollIntoView({
        behavior: "smooth"
    });
});

function animarContador(id, valorFinal, velocidade){
    let atual = 0;

    const contador = setInterval(() => {
        atual += Math.ceil(valorFinal / 100);

        if(atual >= valorFinal){
            atual = valorFinal;
            clearInterval(contador);
        }

        document.getElementById(id).innerText =
        atual.toLocaleString("pt-BR");
    }, velocidade);
}

window.addEventListener("load", () => {
    animarContador("hectares", 5000, 20);
    animarContador("agua", 1200000, 10);
    animarContador("arvores", 8500, 20);
});
